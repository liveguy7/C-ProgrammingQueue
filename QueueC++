#include <iostream>
using namespace std;

//Queue Implementation in C++ with Menu
class Queue {
    private: int front;
    private: int rear;
    private: int arr[5];
    
    public: Queue() {
        front = -1;
        rear = -1;
        for(int i=0; i<5; i++) {
            arr[i] = 0;
        }
    }
    
    public: bool isEmpty() {
        if(front==-1 && rear==-1)
            return true;
        else
            return false;
    }
    
    public: bool isFull() {
        if(rear==4)
            return true;
        else
            return false;
    }
    
    public: void enqueue(int value) {
        if(isFull()) {
            cout << "Queue is Full" << endl;
            return;
        }
        else if(isEmpty()) {
            rear = 0; 
            front = 0;
            arr[rear] = value;
        }
        else {
            rear++;
            arr[rear] = value;
        }
    }
    
    public: int dequeue() {
        int x;
        if(isEmpty()) {
            cout << "Queue is Empty" << endl;
            return 0;
        }
        else if(front == rear) {
            x = arr[front];
            arr[front] = 0;
            rear = -1;
            front = -1;
            return x;
        }
        else {
            x = arr[front];
            arr[front] = 0;
            front++;
            return x;
        }
    }
    
    public: int count() {
        return (rear - front + 1);
    }
    
    public: void display() {
        for(int i=0; i<5; i++) {
            cout << arr[i] << " ";
        }
    }
    
};

int main() {
    Queue *q1 = new Queue();
    int option,value;
    
    do
    {
    cout << "Select an Option: " << endl;
    cout << "1. Enqueue()" << endl;
    cout << "2. Dequeue()" << endl;
    cout << "3. IsEmpty()" << endl;
    cout << "4. IsFull()" << endl;
    cout << "5. Count()" << endl;
    cout << "6. Display()" << endl;
    cout << "7. Clear" << endl;
    
    cout << "Select Here ";
    cin >> option;
    switch(option) {
        case 0:
            break;
        case 1:
            cout << "Add Item to Queue ";
            cin >> value;
            q1->enqueue(value);
            break;
        case 2:
            cout << "Dequeue ";
            cout << q1->dequeue() << endl;
            break;
        case 3:
            if(q1->isEmpty())
                cout << "Queue is Empty" << endl;
            else
                cout << "Queue is not Empty" << endl;
            break;
        case 4:
            if(q1->isFull())
                cout << "Queue is Full" << endl;
            else
                cout << "Queue is Not Full" << endl;
            break;
        case 5:
            cout << "Count Called" << endl;
            cout << q1->count() << endl;
            break;
        case 6:
            cout << "Display Function Called " << endl;
            q1->display();
            break;
        case 7:
            system("cls");
            break;
        default:
            break;
            
    }
}

    while(option != 0);
    
}




